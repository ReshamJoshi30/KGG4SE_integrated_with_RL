<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/sensor_ontology.owl#"
     xml:base="http://example.org/sensor_ontology.owl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:sensor_ontology="http://example.org/sensor_ontology.owl#">
    <owl:Ontology rdf:about="http://example.org/sensor_ontology.owl"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/sensor_ontology.owl#category -->

    <owl:AnnotationProperty rdf:about="http://example.org/sensor_ontology.owl#category"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/sensor_ontology.owl#has_part_directly -->

    <owl:ObjectProperty rdf:about="http://example.org/sensor_ontology.owl#has_part_directly">
        <rdfs:domain rdf:resource="http://example.org/sensor_ontology.owl#Sensor"/>
        <rdfs:range rdf:resource="http://example.org/sensor_ontology.owl#Part"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/sensor_ontology.owl#has_property -->

    <owl:ObjectProperty rdf:about="http://example.org/sensor_ontology.owl#has_property">
        <rdfs:domain rdf:resource="http://example.org/sensor_ontology.owl#Sensor"/>
        <rdfs:range rdf:resource="http://example.org/sensor_ontology.owl#Property"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/sensor_ontology.owl#implements -->

    <owl:ObjectProperty rdf:about="http://example.org/sensor_ontology.owl#implements">
        <rdfs:domain rdf:resource="http://example.org/sensor_ontology.owl#Sensor"/>
        <rdfs:range rdf:resource="http://example.org/sensor_ontology.owl#Technology"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/sensor_ontology.owl# -->

    <owl:Class rdf:about="http://example.org/sensor_ontology.owl#">
        <rdfs:subClassOf rdf:resource="http://example.org/sensor_ontology.owl#Sensor"/>
        <rdfs:subClassOf rdf:resource="http://example.org/sensor_ontology.owl#lidar"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_part_directly"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#applanix_posav_410"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_part_directly"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#data_storage_facilities"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_part_directly"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#oscillating_mirror"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_part_directly"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#power_equipment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_part_directly"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#pulse_frequency"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_part_directly"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#rotating_mirror"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_part_directly"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#trimble_db950_l1/l2"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_property"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#{&apos;component&apos;:_&apos;data_storage_facilities&apos;,_&apos;property&apos;:_&apos;type&apos;,_&apos;value&apos;:_&apos;[10]&apos;}"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_property"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#{&apos;component&apos;:_&apos;pulse_frequency&apos;,_&apos;property&apos;:_&apos;range_(min-max)_[hz]&apos;,_&apos;value&apos;:_&apos;250,000hz&apos;}"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sensor_ontology.owl#has_property"/>
                <owl:someValuesFrom rdf:resource="http://example.org/sensor_ontology.owl#{&apos;component&apos;:_&apos;rotating_mirror&apos;,_&apos;property&apos;:_&apos;scan_angle_(max.)_[deg]&apos;,_&apos;value&apos;:_&apos;150hz&apos;}"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lidar</category>
    </owl:Class>
    


